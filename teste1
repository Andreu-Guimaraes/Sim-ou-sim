<?php
  $pergunta = "Você gosta de mim? 😏";
?>

<h1><?= htmlspecialchars($pergunta) ?></h1>

<div id="area-botoes">
  <button id="btn-sim" onclick="clicarSim()">Sim</button>
  <button id="btn-nao">Não</button>
</div>

<p id="mensagem"></p>

<script>
  const btn = document.getElementById('btn-nao');
  const area = document.getElementById('area-botoes');
  const msg = document.getElementById('mensagem');
  let tentativas = 0;

  btn.addEventListener('mouseenter', function () {
    tentativas++;
    const aw = area.offsetWidth - btn.offsetWidth;
    const ah = area.offsetHeight - btn.offsetHeight;
    const nx = Math.floor(Math.random() * aw);
    const ny = Math.floor(Math.random() * ah);
    btn.style.left = nx + 'px';
    btn.style.top = ny + 'px';

    if (tentativas === 1) msg.textContent = 'Hmm, tenta aí...';
    else if (tentativas === 2) msg.textContent = 'Quase! 😄';
    else if (tentativas === 3) msg.textContent = 'Parece difícil, né? 😂';
    else msg.textContent = 'Esse botão não quer ser clicado! 🏃';
  });

  function clicarSim() {
    msg.textContent = '🎉 Sabia que você ia clicar em Sim!';
    document.getElementById('btn-sim').disabled = true;
    btn.style.display = 'none';
  }
</script>

</body>
</html>
